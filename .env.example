# ─── Admin (CF Worker master key — only needed for first registration) ───
ADMIN_API_KEY=
CF_WORKER_URL=
CF_WORKER_API_KEY=

# ─── Agent Enable Flags ───
ENABLE_GEMINI_CLI=true
ENABLE_CLAUDE_REMOTE_CONTROL=true
ENABLE_CODEX_SERVER=true
ENABLE_OLLAMA_API=true
ENABLE_MFLUX_IMAGE=false

# ─── Node Identity (auto-populated after registration — do not edit) ───
NODE_URL=http://localhost:8017
# NODE_ID=          ← set by register_node.py
# NODE_NAME=        ← set by register_node.py
# NODE_KEY=         ← secret for CF Worker → node task auth
# NODE_TOKEN=nk_... ← SSO token for frontend, API, Infinite Research

# ─── Ollama (optional) ───
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
