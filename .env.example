# ─── Admin (only needed for first registration) ───
ADMIN_API_KEY=
CF_WORKER_URL=
CF_WORKER_API_KEY=

# ─── Agent Enable Flags ───
ENABLE_GEMINI_CLI=true
ENABLE_CLAUDE_REMOTE_CONTROL=true
ENABLE_CODEX_SERVER=true
ENABLE_OLLAMA_API=true
ENABLE_MFLUX_IMAGE=false
ENABLE_VANE_SEARCH=true

# ─── Node Identity (auto-populated after registration — do not edit) ───
NODE_URL=http://localhost:8017
# NODE_ID=
# NODE_NAME=
# NODE_KEY=
# NODE_TOKEN=nk_...

# ─── Ollama (optional) ───
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ─── Vane AI Search (optional) ───
VANE_URL=http://localhost:3000
VANE_CHAT_MODEL=gemma4:26b
VANE_EMBED_MODEL=nomic-embed-text:latest
